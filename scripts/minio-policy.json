{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AppCanReadOwnAndShared",
      "Effect": "Allow",
      "Principal": { "AWS": ["arn:aws:iam::*:user/vaidix-app"] },
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Resource": ["arn:aws:s3:::vaidix-video", "arn:aws:s3:::vaidix-video/*"]
    },
    {
      "Sid": "AppCanWriteAndDeleteWithinScopedPrefixes",
      "Effect": "Allow",
      "Principal": { "AWS": ["arn:aws:iam::*:user/vaidix-app"] },
      "Action": ["s3:PutObject", "s3:DeleteObject", "s3:AbortMultipartUpload"],
      "Resource": [
        "arn:aws:s3:::vaidix-video/recordings/*",
        "arn:aws:s3:::vaidix-video/transcripts/*",
        "arn:aws:s3:::vaidix-video/captions/*",
        "arn:aws:s3:::vaidix-video/documents/*",
        "arn:aws:s3:::vaidix-video/promo/*",
        "arn:aws:s3:::vaidix-video/reels/*",
        "arn:aws:s3:::vaidix-video/dsr-export/*"
      ]
    },
    {
      "Sid": "BlockAnonymousAccess",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:*",
      "Resource": ["arn:aws:s3:::vaidix-video", "arn:aws:s3:::vaidix-video/*"],
      "Condition": { "Bool": { "aws:SecureTransport": "false" } }
    }
  ]
}
