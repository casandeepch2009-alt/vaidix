}

// ════════════════════════════════════════════════════════════════════════════
// CaseTemplate — W6 (library entries; cloned per resident attempt as a Case)
// ════════════════════════════════════════════════════════════════════════════
// Mock-data/cases.json is seeded into this table by `prisma db seed` (W6 P2).
// Faculty curate templates; residents start them, each attempt is a Case row.

model CaseTemplate {
  id                         String         @id @default(cuid())
  legacyId                   String?        @unique // 'case-001' from mock JSON, for migration parity
  title                      String
  condition                  String
  specialty                  String
  topicId                    String?
  /// W6.11 tenancy. Case bank is per-program.
  programId                  String
  bloomsLevel                Int            @default(3) // 1..6
  difficulty                 CaseDifficulty @default(INTERMEDIATE)
  estimatedMinutes           Int            @default(20)
  description                String         @db.Text
  patientName                String
  patientAgeYears            Int
  patientSex                 String
  patientPresentingComplaint String         @db.Text // becomes the opening Message in the resident's conversation
  oslerianPrinciples         String[]
  tags                       String[]
  imageCount                 Int            @default(0)
  isEmergency                Boolean        @default(false)
  publishedAt                DateTime?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  /// Forge / authoring metadata. ownerId is the faculty who authored or
  /// forged this case. Pre-existing seeded templates have ownerId=null
  /// (legacy) and status=PUBLISHED so they keep showing in the resident bank.
  ownerId          String?
  status           CaseTemplateStatus @default(PUBLISHED)
  sourceDocumentId String?
  /// Per-stage AI-mentor guidance — populated by case-forge. Shape:
  /// { patientStory: { mentorIntro, expectedQuestions[], keyFacts[] },
  ///   observation:  { ... }, hypothesis: { differentials[], rationale },
  ///   investigation: { workups[], rationale },
  ///   reflection:    { teachingPoints[], pearls[] } }
  stageGuidance    Json?
  /// Router-v2 analysis result for the AI Coach (review + design passes).
  /// Shape mirrors DeckForgeJob.analysisResult.
  analysisResult   Json?
  forgedAt         DateTime?

  program         Program          @relation(fields: [programId], references: [id])
  topic           Topic?           @relation(fields: [topicId], references: [id])
  owner           User?            @relation("CaseTemplateOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  sourceDocument  Document?        @relation("CaseTemplateSource", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  cases           Case[]
  sessionPreCases SessionPreCase[]

  @@index([programId])
  @@index([specialty])
  @@index([difficulty])
  @@index([topicId])
  @@index([ownerId])
  @@index([status])
  @@index([sourceDocumentId])
  @@map("case_templates")
}

