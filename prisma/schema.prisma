// TIER 0 — AUTH + RBAC (8 tables)
// ════════════════════════════════════════════════════════════════════════════

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  /// Optional alternate login identifiers. Both unique-when-set, both
  /// nullable so existing rows survive the additive migration.
  /// Mobile is stored canonical-form '+91XXXXXXXXXX'. Username is lowercase,
  /// 3-32 chars, [a-z0-9_-]. See identifier primitives in lib/validation.
  mobile            String?    @unique
  username          String?    @unique
  passwordHash      String?
  passwordVersion   Int        @default(1)
  name              String
  role              Role       @default(RESIDENT)
  status            UserStatus @default(PENDING_INVITE)
  avatarUrl         String?
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  failedLoginCount  Int        @default(0)
  lockedUntil       DateTime?
  icalFeedToken     String?    @unique
  /// Optional Program Director uplink for FACULTY users. Service layer
  /// enforces target.role=FACULTY and ref.role=PROGRAM_DIRECTOR. ON DELETE
  /// SET NULL so a PD's removal cleanly orphans their faculty without
  /// blocking the deletion.
  programDirectorId String?
  /// Optional Faculty mentor uplink for RESIDENT users. Service layer
  /// enforces target.role=RESIDENT and ref.role=FACULTY. Independent of
  /// cohort membership — a resident may have a mentor outside their cohort.
  /// ON DELETE SET NULL.
  facultyMentorId   String?
  /// W6.11 multi-tenancy: the program the user is currently viewing. Always a
  /// program they are a member of (enforced at write time in the active-program
  /// endpoint). Nullable only so the additive migration can land before backfill;
  /// post-backfill every active user has a value.
  activeProgramId   String?
  deletedAt         DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  profile                 UserProfile?
  preferences             UserPreferences?
  stats                   UserStats?
  sessions                AuthSession[]
  accounts                AuthAccount[]
  roleHistory             UserRoleHistory[]
  invitationsSent         Invitation[]                  @relation("InvitedBy")
  invitationsAsPD         Invitation[]                  @relation("InvitationPD")
  invitationsAsMentor     Invitation[]                  @relation("InvitationMentor")
  passwordResets          PasswordResetToken[]
  cases                   Case[]
  journalEntries          JournalEntry[]
  bookmarks               Bookmark[]
  messages                Message[]
  conversations           Conversation[]
  scoringEvents           ScoringEvent[]
  reviews                 Review[]
  sessionsHosted          TeachingSession[]             @relation("SessionHost")
  sessionsProposed        TeachingSession[]             @relation("SessionProposer")
  sessionsApproved        TeachingSession[]             @relation("SessionApprover")
  cohortsCreated          Cohort[]                      @relation("CohortCreator")
  cohortsAsFaculty        Cohort[]                      @relation("CohortFaculty")
  cohortMemberships       CohortMember[]                @relation("CohortMembership")
  programDirector         User?                         @relation("FacultyToPD", fields: [programDirectorId], references: [id], onDelete: SetNull)
  facultyMembers          User[]                        @relation("FacultyToPD")
  facultyMentor           User?                         @relation("ResidentToFaculty", fields: [facultyMentorId], references: [id], onDelete: SetNull)
  mentees                 User[]                        @relation("ResidentToFaculty")
  sessionInvites          SessionInvite[]               @relation("SessionInviteUser")
  sessionAdmissions       SessionAdmission[]            @relation("SessionAdmissionUser")
  admissionDecisions      SessionAdmission[]            @relation("SessionAdmissionDecider")
  sessionApprovalAudits   SessionApprovalAudit[]        @relation("SessionApprovalActor")
  sessionParticipations   SessionParticipant[]
  chatMessagesSent        SessionChatMessage[]
  documentsUploaded       Document[]                    @relation("DocumentUploader")
  qaItems                 QaItem[]
  qaReactions             QaReaction[]
  dopsResident            DopsAssessment[]              @relation("DopsResident")
  dopsAssessor            DopsAssessment[]              @relation("DopsAssessor")
  miniCexResident         MiniCexAssessment[]           @relation("MiniCexResident")
  miniCexAssessor         MiniCexAssessment[]           @relation("MiniCexAssessor")
  epaRecords              EpaRecord[]
  trainingFeedback        TrainingFeedback[]
  enrollments             CourseEnrollment[]
  completions             CourseCompletion[]
  recommendations         Recommendation[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  safetyEscalations       SafetyEscalation[]
  auditEvents             AuditEvent[]                  @relation("AuditActor")
  adminActions            AdminAction[]                 @relation("AdminActor")
  dpdpaRequests           DpdpaRequest[]                @relation("DpdpaSubject")
  consentRecords          ConsentRecord[]
  gamificationPoints      GamificationPoint[]
  cmeCredits              CmeCredit[]
  sessionBans             SessionBan[]
  deckForgeJobs           DeckForgeJob[]
  blueprints              Blueprint[]                   @relation("BlueprintRequester")
  simulatorRuns           SimulatorRun[]
  challengeAttempts       ChallengeAttempt[]
  vcceResults             VcceResult[]
  apiKeys                 ApiKey[]
  modulePermissions       UserModulePermission[]
  engagementSignals       EngagementSignal[]
  liveHookResponses       LiveHookResponse[]
  presenterAlerts         PresenterAlert[]
  kirkpatrickEvaluations  KirkpatrickEvaluation[]
  breakoutsCreated        Breakout[]                    @relation("BreakoutCreator")
  breakoutAssignments     BreakoutParticipant[]
  recordingSharesCreated  RecordingShare[]              @relation("RecordingShareCreator")
  recordingSharesRevoked  RecordingShare[]              @relation("RecordingShareRevoker")
  promoSharesCreated      PromoShare[]                  @relation("PromoShareCreator")
  promoSharesRevoked      PromoShare[]                  @relation("PromoShareRevoker")
  preQuestionsAsked       PreSessionQuestion[]
  preQuestionVotes        PreSessionQuestionVote[]
  sessionPreCases         SessionPreCase[]              @relation("SessionPreCaseAssigner")
  studyPackViews          StudyPackView[]
  objectiveAchievements   SessionObjectiveAchievement[]
  programMemberships      ProgramMembership[]
  activeProgram           Program?                      @relation("UserActiveProgram", fields: [activeProgramId], references: [id], onDelete: SetNull)
  sharedNoteEdits         SharedNoteEdit[]
  webinarRegistrations    WebinarRegistration[]
  sessionFilesUploaded    SessionFile[]                 @relation("SessionFileUploader")
  whiteboardSnapshots     WhiteboardSnapshot[]          @relation("WhiteboardSnapshotAuthor")
  caseTemplatesAuthored   CaseTemplate[]                @relation("CaseTemplateOwner")
  // Per-faculty AI style memory — raw edit signals captured during deck refinement,
  // and the distilled rule profile that gets injected into the next forge prompt.
  facultyEditSignals      FacultyEditSignal[]
  facultyStyleProfile     FacultyStyleProfile?

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([programDirectorId])
  @@index([facultyMentorId])
  @@index([activeProgramId])
  @@map("users")
}

// ════════════════════════════════════════════════════════════════════════════
// Program — W6.11 Multi-tenancy entry point
// ════════════════════════════════════════════════════════════════════════════
// A "program" is one residency / fellowship curriculum at one institution
// (e.g. "LVPEI MS Ophthalmology", "LVPEI Cornea Fellowship"). Tenant boundary
// for the 6 entry-point domain tables (Cohort, TeachingSession, Topic,
// CaseTemplate, Pearl, Course). All other domain rows are scoped transitively
// through these (a Document attached to a session inherits the session's program).
//
// Users belong to programs via ProgramMembership (N:M) with an optional role
// override per program — a faculty in MS Ophthalmology might be PD of Cornea
// Fellowship. The role on User remains the user's "primary" role for
// invitation / sidebar shaping; the membership role takes precedence inside
// each program's UI.

model Program {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  /// Free-text specialty label e.g. "Ophthalmology", "Cornea". Used for
  /// header chips. The 16-topic ophthalmology subspecialty list lives in
  /// Topic; specialty here is coarser (one program-wide string).
  specialty   String?
  /// Free-text institution name e.g. "LVPEI Hyderabad". Single string instead
  /// of an Institution model — the second-tenancy-axis (one institution can
  /// host multiple programs) is a v2 concern; flatten for now.
  institution String?
  description String?       @db.Text
  status      ProgramStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  memberships      ProgramMembership[]
  activeForUsers   User[]              @relation("UserActiveProgram")
  cohorts          Cohort[]
  teachingSessions TeachingSession[]
  topics           Topic[]
  caseTemplates    CaseTemplate[]
  pearls           Pearl[]
  courses          Course[]

  @@index([status])
  @@map("programs")
}

// ════════════════════════════════════════════════════════════════════════════
// ProgramMembership — User × Program with optional role override
// ════════════════════════════════════════════════════════════════════════════
// Same person can be RESIDENT in MS Ophth, EXTERNAL_LEARNER in Cornea
// Fellowship, FACULTY in Glaucoma Fellowship. `role` here null = use User.role.

model ProgramMembership {
  id        String   @id @default(cuid())
  userId    String
  programId String
  /// Optional per-program role override. Null = inherit User.role. Service
  /// layer at active-program switch time uses (override ?? user.role) to
  /// shape sidebars and route guards inside that program.
  role      Role?
  addedAt   DateTime @default(now())
  addedBy   String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([userId])
  @@index([programId])
  @@map("program_memberships")
}

// NextAuth account links (OAuth or credentials provider link)
model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Invitation {
  id                String           @id @default(cuid())
  email             String
  fullName          String?
  mobile            String?
  mciRegNumber      String?
  role              Role
  subspecialty      String?
  department        String?
  yearOfResidency   Int?
  moduleOverrides   Json?
  /// Optional Program Director uplink applied on accept when role=FACULTY.
  /// Service layer enforces ref.role=PROGRAM_DIRECTOR. ON DELETE SET NULL so
  /// removing a PD doesn't cascade-revoke pending faculty invites.
  programDirectorId String?
  /// Optional Faculty mentor uplink applied on accept when role=RESIDENT.
  /// Service enforces ref.role=FACULTY. ON DELETE SET NULL.
  facultyMentorId   String?
  /// Optional cohort assignment applied on accept when role=RESIDENT.
  /// Becomes a CohortMember row at acceptance. ON DELETE SET NULL.
  cohortId          String?
  /// Optional pre-set profile photo. Carried over to User.avatarUrl on accept.
  avatarUrl         String?
  /// Optional gender pre-fill. Carried over to UserProfile.gender on accept.
  gender            String?
  token             String           @unique
  status            InvitationStatus @default(PENDING)
  invitedById       String
  acceptedAt        DateTime?
  acceptedUserId    String?
  expiresAt         DateTime
  revokedAt         DateTime?
  revokedReason     String?
  lastResentAt      DateTime?
  resendCount       Int              @default(0)
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  invitedBy       User    @relation("InvitedBy", fields: [invitedById], references: [id])
  programDirector User?   @relation("InvitationPD", fields: [programDirectorId], references: [id], onDelete: SetNull)
  facultyMentor   User?   @relation("InvitationMentor", fields: [facultyMentorId], references: [id], onDelete: SetNull)
  cohort          Cohort? @relation("InvitationCohort", fields: [cohortId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
  @@index([token])
  @@index([programDirectorId])
  @@index([facultyMentorId])
  @@index([cohortId])
  @@map("invitations")
}

model UserModulePermission {
  id        String    @id @default(cuid())
  userId    String
  moduleKey String
  granted   Boolean
  grantedBy String?
  reason    String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
