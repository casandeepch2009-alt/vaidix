// One row per slide produced by a DeckForgeJob. Slides are first-class:
// editable, reorderable, and the source of truth for both the in-app
// presenter and the .pptx export. PPT files are an export, never canonical.
model Slide {
  id              String      @id @default(cuid())
  deckForgeJobId  String
  order           Int // 0-based, contiguous within a deck
  layout          SlideLayout @default(TITLE_BULLETS)
  title           String      @db.Text
  bullets         String[] // top-level bullet points
  speakerNotes    String?     @db.Text
  // [{ documentId?, recordingId?, transcriptStart?, transcriptEnd?, page? }]
  sourceCitations Json?
  // Optional accent color override (hex, no '#'); else inherits theme.
  accentHex       String?
  // Wizard-forge image asset (populated post-draft by aiGenerateImageForSlide).
  // Null when generation was skipped (non-IMAGE_FOCUS layout) or failed
  // (best-effort — a missing image never blocks the deck). The deck-pptx
  // renderer fetches the S3 object and paints it into IMAGE_FOCUS slides;
  // falls back to the dashed placeholder when null/fetch fails.
  imageS3Key      String?
  // The prompt aiGenerateImagePrompt produced — kept for audit and so
  // faculty can regenerate with a tweaked prompt from the Studio later.
  imagePrompt     String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  job DeckForgeJob @relation(fields: [deckForgeJobId], references: [id], onDelete: Cascade)

  @@unique([deckForgeJobId, order])
  @@index([deckForgeJobId])
  @@map("slides")
