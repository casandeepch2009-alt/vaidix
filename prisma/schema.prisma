// ════════════════════════════════════════════════════════════════════════════
// Vaidix — Prisma Schema v1.0
// ════════════════════════════════════════════════════════════════════════════
// 42 domains · ~94 tables · 11 tiers · Initial migration: initial_schema_v1
// Date: 2026-04-13
// Locked per Week 0 / Approach C (holistic design, one migration).
// See: Vaidix-Build-Approach.md, VAIDIX-BUILD-PLAN-NOW.md
// ════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

