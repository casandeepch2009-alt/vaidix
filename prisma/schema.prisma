  slug        String   @unique
  name        String
  description String?
  modality    String // 'OCT_READ' | 'FUNDUS_READ' | 'VF_READ' | 'DIAGNOSTIC'
  topicId     String?
  config      Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  runs SimulatorRun[]

  @@map("simulators")
}

model SimulatorRun {
  id          String   @id @default(cuid())
  simulatorId String
  userId      String
  score       Decimal? @db.Decimal(4, 2)
  durationSec Int?
  answers     Json
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  simulator Simulator @relation(fields: [simulatorId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([simulatorId])
  @@index([userId])
