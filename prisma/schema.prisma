// ════════════════════════════════════════════════════════════════════════════
// TIER 0 — AUTH + RBAC (8 tables)
// ════════════════════════════════════════════════════════════════════════════

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  /// Optional alternate login identifiers. Both unique-when-set, both
  /// nullable so existing rows survive the additive migration.
  /// Mobile is stored canonical-form '+91XXXXXXXXXX'. Username is lowercase,
  /// 3-32 chars, [a-z0-9_-]. See identifier primitives in lib/validation.
  mobile           String?    @unique
  username         String?    @unique
  passwordHash     String?
  passwordVersion  Int        @default(1)
  name             String
  role             Role       @default(RESIDENT)
  status           UserStatus @default(PENDING_INVITE)
  avatarUrl        String?
  emailVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  icalFeedToken    String?    @unique
  /// Optional Program Director uplink for FACULTY users. Service layer
  /// enforces target.role=FACULTY and ref.role=PROGRAM_DIRECTOR. ON DELETE
  /// SET NULL so a PD's removal cleanly orphans their faculty without
  /// blocking the deletion.
  programDirectorId String?
  deletedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  profile                 UserProfile?
  preferences             UserPreferences?
  stats                   UserStats?
  sessions                AuthSession[]
  accounts                AuthAccount[]
  roleHistory             UserRoleHistory[]
  invitationsSent         Invitation[]             @relation("InvitedBy")
  passwordResets          PasswordResetToken[]
  cases                   Case[]
  journalEntries          JournalEntry[]
  bookmarks               Bookmark[]
  messages                Message[]
  conversations           Conversation[]
  scoringEvents           ScoringEvent[]
  reviews                 Review[]
  sessionsHosted          TeachingSession[]        @relation("SessionHost")
  sessionsProposed        TeachingSession[]        @relation("SessionProposer")
  sessionsApproved        TeachingSession[]        @relation("SessionApprover")
  cohortsCreated          Cohort[]                 @relation("CohortCreator")
  cohortsAsFaculty        Cohort[]                 @relation("CohortFaculty")
  cohortMemberships       CohortMember[]           @relation("CohortMembership")
  programDirector         User?                    @relation("FacultyToPD", fields: [programDirectorId], references: [id], onDelete: SetNull)
  facultyMembers          User[]                   @relation("FacultyToPD")
  sessionInvites          SessionInvite[]          @relation("SessionInviteUser")
  sessionAdmissions       SessionAdmission[]       @relation("SessionAdmissionUser")
  admissionDecisions      SessionAdmission[]       @relation("SessionAdmissionDecider")
  sessionApprovalAudits   SessionApprovalAudit[]   @relation("SessionApprovalActor")
  sessionParticipations   SessionParticipant[]
  chatMessagesSent        SessionChatMessage[]
  documentsUploaded       Document[]               @relation("DocumentUploader")
  qaItems                 QaItem[]
  qaReactions             QaReaction[]
  dopsResident            DopsAssessment[]         @relation("DopsResident")
  dopsAssessor            DopsAssessment[]         @relation("DopsAssessor")
  miniCexResident         MiniCexAssessment[]      @relation("MiniCexResident")
  miniCexAssessor         MiniCexAssessment[]      @relation("MiniCexAssessor")
  epaRecords              EpaRecord[]
  trainingFeedback        TrainingFeedback[]
  enrollments             CourseEnrollment[]
  completions             CourseCompletion[]
  recommendations         Recommendation[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  safetyEscalations       SafetyEscalation[]
  auditEvents             AuditEvent[]             @relation("AuditActor")
  adminActions            AdminAction[]            @relation("AdminActor")
  dpdpaRequests           DpdpaRequest[]           @relation("DpdpaSubject")
  consentRecords          ConsentRecord[]
  gamificationPoints      GamificationPoint[]
  cmeCredits              CmeCredit[]
  sessionBans             SessionBan[]
  deckForgeJobs           DeckForgeJob[]
  simulatorRuns           SimulatorRun[]
  challengeAttempts       ChallengeAttempt[]
  vcceResults             VcceResult[]
  apiKeys                 ApiKey[]
  modulePermissions       UserModulePermission[]
  engagementSignals       EngagementSignal[]
  liveHookResponses       LiveHookResponse[]
  presenterAlerts         PresenterAlert[]
  kirkpatrickEvaluations  KirkpatrickEvaluation[]
  breakoutsCreated        Breakout[]               @relation("BreakoutCreator")
  breakoutAssignments     BreakoutParticipant[]
  recordingSharesCreated  RecordingShare[]         @relation("RecordingShareCreator")
  recordingSharesRevoked  RecordingShare[]         @relation("RecordingShareRevoker")
  preQuestionsAsked       PreSessionQuestion[]
  preQuestionVotes        PreSessionQuestionVote[]
  sessionPreCases         SessionPreCase[]              @relation("SessionPreCaseAssigner")
  studyPackViews          StudyPackView[]
  objectiveAchievements   SessionObjectiveAchievement[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([programDirectorId])
  @@map("users")
}

// NextAuth account links (OAuth or credentials provider link)
model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Invitation {
  id              String           @id @default(cuid())
  email           String
  fullName        String?
  mobile          String?
  mciRegNumber    String?
  role            Role
  subspecialty    String?
  department      String?
  yearOfResidency Int?
  moduleOverrides Json?
  token           String           @unique
  status          InvitationStatus @default(PENDING)
  invitedById     String
  acceptedAt      DateTime?
  acceptedUserId  String?
  expiresAt       DateTime
  revokedAt       DateTime?
  revokedReason   String?
  lastResentAt    DateTime?
  resendCount     Int              @default(0)
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([email])
  @@index([status])
  @@index([token])
  @@map("invitations")
}

model UserModulePermission {
  id        String    @id @default(cuid())
  userId    String
  moduleKey String
  granted   Boolean
  grantedBy String?
  reason    String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleKey])
  @@index([userId])
  @@map("user_module_permissions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

model RateLimit {
  id           String    @id @default(cuid())
  bucketKey    String // e.g. "login:email:user@x.com" or "login:ip:1.2.3.4"
  hitCount     Int       @default(0)
  windowStart  DateTime  @default(now())
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([bucketKey])
  @@index([blockedUntil])
  @@map("rate_limits")
}

model UserRoleHistory {
  id           String   @id @default(cuid())
  userId       String
  previousRole Role?
  newRole      Role
  changedBy    String
  reason       String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_role_history")
}

// ════════════════════════════════════════════════════════════════════════════
// TIER 1 — CORE LEARNER (12 tables)
// ════════════════════════════════════════════════════════════════════════════

model Topic {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  subspecialty  String? // Cornea, Glaucoma, Retina, Pediatric, etc.
  description   String?
  parentTopicId String?
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  parent        Topic?         @relation("TopicHierarchy", fields: [parentTopicId], references: [id])
  children      Topic[]        @relation("TopicHierarchy")
  cases         Case[]
  caseTemplates CaseTemplate[]
  pearls        Pearl[]
  courses       Course[]
  atlasImages   AtlasImage[]

  @@index([parentTopicId])
  @@index([subspecialty])
  @@map("topics")
}

model Level {
  id          String   @id @default(cuid())
  levelNumber Int      @unique // 1-4
  name        String
  description String?
  minMastery  Int // score threshold
  createdAt   DateTime @default(now())

  userProgress UserLevelProgress[]

  @@map("levels")
}

model UserLevelProgress {
  id           String    @id @default(cuid())
  userId       String
  topicId      String
  levelId      String
  masteryScore Int       @default(0)
  unlockedAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  level Level @relation(fields: [levelId], references: [id])

  @@unique([userId, topicId, levelId])
  @@index([userId])
  @@index([topicId])
  @@map("user_level_progress")
}

model Case {
  id                  String     @id @default(cuid())
  residentId          String
  templateId          String?
  topicId             String?
  title               String
  patientAgeYears     Int?
  patientSex          String?
  presentingComplaint String?
  currentStage        CaseStage  @default(PATIENT_STORY)
  status              CaseStatus @default(ACTIVE)
  difficultyLevel     Int        @default(1)
  caseNotes           String?    @db.Text // faculty-loaded reference; PHI-scanned
  deletedAt           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  resident      User               @relation(fields: [residentId], references: [id])
  template      CaseTemplate?      @relation(fields: [templateId], references: [id])
  topic         Topic?             @relation(fields: [topicId], references: [id])
  conversations Conversation[]
  stageHistory  CaseStageHistory[]
  scoringEvents ScoringEvent[]

  @@index([residentId])
  @@index([templateId])
  @@index([topicId])
  @@index([status])
  @@index([currentStage])
  @@map("cases")
}

// ════════════════════════════════════════════════════════════════════════════
// CaseTemplate — W6 (library entries; cloned per resident attempt as a Case)
// ════════════════════════════════════════════════════════════════════════════
// Mock-data/cases.json is seeded into this table by `prisma db seed` (W6 P2).
// Faculty curate templates; residents start them, each attempt is a Case row.

model CaseTemplate {
  id                         String         @id @default(cuid())
  legacyId                   String?        @unique // 'case-001' from mock JSON, for migration parity
  title                      String
  condition                  String
  specialty                  String
  topicId                    String?
  bloomsLevel                Int            @default(3) // 1..6
  difficulty                 CaseDifficulty @default(INTERMEDIATE)
  estimatedMinutes           Int            @default(20)
  description                String         @db.Text
  patientName                String
  patientAgeYears            Int
  patientSex                 String
  patientPresentingComplaint String         @db.Text // becomes the opening Message in the resident's conversation
  oslerianPrinciples         String[]
  tags                       String[]
  imageCount                 Int            @default(0)
  isEmergency                Boolean        @default(false)
  publishedAt                DateTime?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  topic           Topic?           @relation(fields: [topicId], references: [id])
  cases           Case[]
  sessionPreCases SessionPreCase[]

  @@index([specialty])
  @@index([difficulty])
  @@index([topicId])
  @@map("case_templates")
}

model CaseStageHistory {
  id        String     @id @default(cuid())
  caseId    String
  fromStage CaseStage?
  toStage   CaseStage
  reason    String?
  createdAt DateTime   @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_stage_history")
}

model Conversation {
  id        String             @id @default(cuid())
  caseId    String
  userId    String
  stage     CaseStage
  status    ConversationStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  case     Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])
  messages Message[]

  @@index([caseId])
  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  userId         String?
  senderRole     String // 'RESIDENT' | 'AI' | 'FACULTY'
  content        String   @db.Text
  aiModelVersion String?
  tokenCount     Int?
  metadata       Json?
  flaggedSafety  Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([conversationId])
  @@index([userId])
  @@index([createdAt])
  @@map("messages")
}

// APPEND-ONLY. Never UPDATE or DELETE.
model ScoringEvent {
  id                       String        @id @default(cuid())
  residentId               String
  sourceType               ScoringSource
  sourceId                 String // references case.id, dops.id, quiz.id etc.
  caseId                   String?
  // Triple-H subscores (0-5 each)
  headClinicalReasoning    Int?
  headEvidenceBase         Int?
  headDifferentialBuilding Int?
  headInvestigationChoice  Int?
  heartEmpathy             Int?
  heartCommunication       Int?
  heartCulturalCompetence  Int?
  heartProfessionalism     Int?
  handsProcedure           Int?
  handsExamTechnique       Int?
  handsInstrumentation     Int?
  handsSafetyHabits        Int?
  // Aggregates (computed on insert)
  headScore                Decimal?      @db.Decimal(4, 2)
  heartScore               Decimal?      @db.Decimal(4, 2)
  handsScore               Decimal?      @db.Decimal(4, 2)
  // Context
  reviewerId               String?
  comments                 String?       @db.Text
  voidedAt                 DateTime?
  voidedReason             String?
  createdAt                DateTime      @default(now())

  resident User  @relation(fields: [residentId], references: [id])
  case     Case? @relation(fields: [caseId], references: [id])

  @@index([residentId, createdAt])
  @@index([sourceType, sourceId])
  @@index([caseId])
  @@map("scoring_events")
}

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  title      String?
  body       String   @db.Text
  tags       String[]
  caseId     String?
  sessionId  String?
  prompted   Boolean  @default(false)
  promptType String? // e.g. 'POST_SESSION_REFLECTION', 'WHAT_LEARNED', 'WHAT_UNCLEAR', 'CLINICAL_APPLICATION'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([caseId])
  @@index([sessionId])
  @@index([prompted])
  @@map("journal_entries")
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  targetType String // 'PEARL' | 'RECORDING' | 'COURSE_ITEM' | 'ATLAS_IMAGE' | 'DOCUMENT'
  targetId   String
  note       String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId])
  @@map("bookmarks")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ReviewItem[]

  @@index([userId])
  @@map("reviews")
}

model ReviewItem {
  id             String    @id @default(cuid())
  reviewId       String
  targetType     String // 'PEARL' | 'ATLAS_IMAGE' | 'CASE' | 'COURSE_ITEM'
  targetId       String
  easinessFactor Float     @default(2.5)
  intervalDays   Int       @default(1)
  repetitions    Int       @default(0)
  lastReviewedAt DateTime?
  nextDueAt      DateTime
  lastQuality    Int? // 0-5 SM-2
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([nextDueAt])
  @@map("review_items")
}

// ════════════════════════════════════════════════════════════════════════════
// TIER 2 — KNOWLEDGE LIBRARY (8 tables)
// ════════════════════════════════════════════════════════════════════════════

model Pearl {
  id                String    @id @default(cuid())
  title             String
  body              String    @db.Text
  topicId           String?
  sourceType        String // 'recording' | 'document' | 'manual' | 'ai_extracted'
  sourceRecordingId String?
  sourceDocumentId  String?
  extractedByAi     Boolean   @default(false)
  approved          Boolean   @default(false)
  approvedById      String?
  approvedAt        DateTime?
  citations         Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  topic Topic?      @relation(fields: [topicId], references: [id])
  likes PearlLike[]

  @@index([topicId])
  @@index([approved])
  @@index([sourceRecordingId])
  @@map("pearls")
}

model PearlLike {
  id        String   @id @default(cuid())
  pearlId   String
  userId    String
  createdAt DateTime @default(now())

  pearl Pearl @relation(fields: [pearlId], references: [id], onDelete: Cascade)

  @@unique([pearlId, userId])
  @@index([pearlId])
  @@map("pearl_likes")
}

model AtlasImage {
  id               String   @id @default(cuid())
  title            String
  description      String?
  imageUrl         String
  thumbnailUrl     String?
  topicId          String?
  uploadedById     String?
  caption          String?
  anatomicalRegion String?
  modality         String? // 'OCT' | 'FUNDUS' | 'SLIT_LAMP' | 'CLINICAL'
  visibility       String   @default("PUBLIC")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  topic Topic?     @relation(fields: [topicId], references: [id])
  tags  AtlasTag[]

  @@index([topicId])
  @@index([modality])
  @@map("atlas_images")
}

model AtlasTag {
  id      String @id @default(cuid())
  imageId String
  tag     String

  image AtlasImage @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([imageId, tag])
  @@index([tag])
  @@map("atlas_tags")
}

model RagCollection {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  description    String?
  vectorStore    String // 'qdrant'
  embeddingModel String    @default("bge-m3")
  dimensions     Int       @default(1024)
  docCount       Int       @default(0)
  chunkCount     Int       @default(0)
  lastIndexedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  documents RagDocument[]

  @@map("rag_collections")
}

model RagDocument {
  id           String    @id @default(cuid())
  collectionId String
  sourceType   String // 'document' | 'recording_transcript' | 'manual'
  sourceId     String?
  title        String
  chunkCount   Int       @default(0)
  indexedAt    DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())

  collection RagCollection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  chunks     RagChunkMeta[]

  @@index([collectionId])
  @@index([sourceType, sourceId])
  @@map("rag_documents")
}

model RagChunkMeta {
  id          String   @id @default(cuid())
  documentId  String
  qdrantId    String   @unique // vector DB ID
  chunkIndex  Int
  textPreview String   @db.Text
  tokenCount  Int
  createdAt   DateTime @default(now())

  document RagDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("rag_chunks_meta")
}

model Citation {
  id            String   @id @default(cuid())
  sourceType    String // 'pearl' | 'message' | 'course_item'
  sourceId      String
  chunkMetaId   String?
  url           String?
  title         String?
  author        String?
  publishedYear Int?
  confidence    Decimal? @db.Decimal(3, 2)
  createdAt     DateTime @default(now())

  @@index([sourceType, sourceId])
  @@map("citations")
}

// ════════════════════════════════════════════════════════════════════════════
// TIER 3 — PRACTICE TOOLS (3 tables)
