// Faculty intent at the start of the forge wizard. Branches the AI prompt
// and the input rules.
//   ENHANCE_EXISTING   — exactly 1 PRIMARY_PPTX + 0..N SOURCE refs. AI keeps
//                        the deck shape, proposes content/density/visual edits.
//   DRAFT_FROM_SCRATCH — no PRIMARY_PPTX, 1..N SOURCE / PRIOR_TRANSCRIPT.
//                        AI authors a deck from briefing + extracted content.
enum DeckForgeIntent {
  ENHANCE_EXISTING
  DRAFT_FROM_SCRATCH
}

// Role of each Document attached to a DeckForgeJob.
enum DeckForgeInputRole {
  PRIMARY_PPTX // Faculty's deck-to-enhance. ENHANCE_EXISTING only, exactly 1.
  SOURCE // Reference material the AI reads to compose / enhance content.
  PRIOR_TRANSCRIPT // A previous session transcript — "I've taught this before."
}

