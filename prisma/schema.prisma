model DopsAssessment {
  id             String            @id @default(cuid())
  residentId     String
  assessorId     String
  procedureName  String
  procedureCode  String?
  outcome        AssessmentOutcome
  location       String?
  comments       String?           @db.Text
  artifacts      Json? // images/video references
  scoringEventId String?
  performedAt    DateTime
  createdAt      DateTime          @default(now())

  resident User @relation("DopsResident", fields: [residentId], references: [id])
  assessor User @relation("DopsAssessor", fields: [assessorId], references: [id])

  @@index([residentId])
  @@index([assessorId])
  @@map("dops_assessments")
}

model MiniCexAssessment {
  id             String            @id @default(cuid())
  residentId     String
  assessorId     String
  encounterType  String
  complexity     Int               @default(1)
  outcome        AssessmentOutcome
  domainScores   Json // per-domain ratings
  comments       String?           @db.Text
  scoringEventId String?
  performedAt    DateTime
  createdAt      DateTime          @default(now())

  resident User @relation("MiniCexResident", fields: [residentId], references: [id])
  assessor User @relation("MiniCexAssessor", fields: [assessorId], references: [id])

