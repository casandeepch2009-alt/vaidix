// ════════════════════════════════════════════════════════════════════════════
// TIER 5 — TEACHING, COHORT & DOCUMENTS (12 tables)
// ════════════════════════════════════════════════════════════════════════════

model TeachingSession {
  id                  String                @id @default(cuid())
  title               String
  description         String?               @db.Text
  sessionType         SessionType
  hostId              String
  status              SessionStatus         @default(SCHEDULED)
  approvalStatus      SessionApprovalStatus @default(DRAFT)
  visibility          SessionVisibility     @default(OPEN_TO_ALL)
  proposedBy          String
  approvedBy          String?
  approvedAt          DateTime?
  rejectedReason      String?
  cohortId            String?
  scheduledStart      DateTime
  scheduledEnd        DateTime
  actualStart         DateTime?
  actualEnd           DateTime?
  recurrenceRule      String?
  recurrenceUntil     DateTime?
  parentSessionId     String?
  shareToken          String?               @unique
  shareTokenExpiresAt DateTime?
  liveKitRoomSid      String?
  maxParticipants     Int                   @default(100)
  breakoutsEnabled    Boolean               @default(false)
  recordingEnabled    Boolean               @default(true)
  consentRequired     Boolean               @default(true)
  hlsBroadcast        Boolean               @default(false)
  topicId             String?
  tags                String[]
  metadata            Json?
  // Structured learning objectives — array of { id, text, blooms, epaTag? }.
  // Stored as Json so curators can reorder/edit without a sub-table; resident
  // self-marks live in SessionObjectiveAchievement keyed by the objective id.
  objectives          Json?
  deletedAt           DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  host                   User                           @relation("SessionHost", fields: [hostId], references: [id])
  proposer               User                           @relation("SessionProposer", fields: [proposedBy], references: [id])
  approver               User?                          @relation("SessionApprover", fields: [approvedBy], references: [id])
  cohort                 Cohort?                        @relation(fields: [cohortId], references: [id])
  parentSession          TeachingSession?               @relation("SessionSeries", fields: [parentSessionId], references: [id])
  childSessions          TeachingSession[]              @relation("SessionSeries")
  participants           SessionParticipant[]
  chatMessages           SessionChatMessage[]
  recording              Recording?
  documentLinks          DocumentSessionLink[]
  bans                   SessionBan[]
  auditEvents            SessionAuditEvent[]
  invites                SessionInvite[]
  admissions             SessionAdmission[]
  approvalAudits         SessionApprovalAudit[]
  engagementSignals      EngagementSignal[]
  liveHooks              LiveHook[]
  presenterAlerts        PresenterAlert[]
  kirkpatrickEvaluations KirkpatrickEvaluation[]
  breakouts              Breakout[]
  preQuestions           PreSessionQuestion[]
  preQuestionThemes      PreSessionQuestionTheme[]
  preCases               SessionPreCase[]
  studyPackViews         StudyPackView[]
  objectiveAchievements  SessionObjectiveAchievement[]

  @@index([hostId])
  @@index([proposedBy])
  @@index([approvalStatus])
  @@index([visibility])
  @@index([cohortId])
  @@index([status])
  @@index([scheduledStart])
  @@index([scheduledEnd])
  @@index([parentSessionId])
  @@map("teaching_sessions")
}

model SessionParticipant {
  id              String    @id @default(cuid())
  sessionId       String
  userId          String
  joinedAt        DateTime?
  leftAt          DateTime?
  role            String // 'HOST' | 'CO_HOST' | 'PARTICIPANT' | 'VIEWER'
  livekitIdentity String?
  createdAt       DateTime  @default(now())

  session TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@map("session_participants")
}

model SessionChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  session TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id])

  @@index([sessionId, createdAt])
  @@map("session_chat_messages")
}

model SessionBan {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  reason    String?
  bannedBy  String
  createdAt DateTime @default(now())

  session TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@map("session_bans")
}

// ---------------------------------------------------------------------------
// Domain 32 — Session Scheduling & Calendar
// ---------------------------------------------------------------------------
// Cohort: named group of residents (e.g., "2026 Retina Fellows"). Used for
// COHORT-visibility sessions — all members see the session on their calendar.

model Cohort {
  id           String       @id @default(cuid())
  name         String
  description  String?      @db.Text
  academicYear String?
  status       CohortStatus @default(ACTIVE)
  createdBy    String
  /// Optional faculty mentor for this cohort. Service layer enforces that the
  /// referenced user has role=FACULTY. ON DELETE SET NULL so a faculty
  /// departure / soft-delete leaves the cohort intact, just unmapped.
  facultyId    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  creator  User              @relation("CohortCreator", fields: [createdBy], references: [id])
  faculty  User?             @relation("CohortFaculty", fields: [facultyId], references: [id], onDelete: SetNull)
  members  CohortMember[]
  sessions TeachingSession[]

  @@index([status])
  @@index([createdBy])
  @@index([facultyId])
  @@map("cohorts")
}

model CohortMember {
  id       String   @id @default(cuid())
  cohortId String
  userId   String
  addedBy  String
  addedAt  DateTime @default(now())

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User   @relation("CohortMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortId, userId])
  @@index([cohortId])
  @@index([userId])
  @@map("cohort_members")
}

// SessionInvite: explicit invite list for INVITE_ONLY sessions. Also captures
// per-user RSVP state separately from actual attendance (SessionParticipant).

model SessionInvite {
  id          String              @id @default(cuid())
  sessionId   String
  userId      String
  status      SessionInviteStatus @default(INVITED)
  invitedBy   String
  invitedAt   DateTime            @default(now())
  respondedAt DateTime?

  session TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation("SessionInviteUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId, status])
  @@map("session_invites")
}

// SessionAdmission: waiting-room entries for users who don't match the
// visibility rules but joined via share link or guest flow. Host/co-host
// admits or denies.

model SessionAdmission {
  id          String          @id @default(cuid())
  sessionId   String
  userId      String
  status      AdmissionStatus @default(PENDING)
  displayName String?
  requestedAt DateTime        @default(now())
  decidedAt   DateTime?
  decidedBy   String?
  denyReason  String?

  session TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation("SessionAdmissionUser", fields: [userId], references: [id], onDelete: Cascade)
  decider User?           @relation("SessionAdmissionDecider", fields: [decidedBy], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId, status])
  @@index([userId])
  @@map("session_admissions")
}

// SessionApprovalAudit: append-only log of approval state transitions.
// Every PROPOSED / APPROVED / REJECTED / CANCELLED / RESCHEDULED action is logged.

model SessionApprovalAudit {
  id        String                @id @default(cuid())
  sessionId String
  actorId   String
  action    SessionApprovalAction
  reason    String?               @db.Text
  metadata  Json?
  createdAt DateTime              @default(now())

  session TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actor   User            @relation("SessionApprovalActor", fields: [actorId], references: [id])

  @@index([sessionId, createdAt])
  @@index([actorId])
  @@map("session_approval_audits")
}

model Recording {
  id                   String          @id @default(cuid())
  sessionId            String          @unique
  status               RecordingStatus @default(RECORDING)
  pipelineStage        RecordingStatus @default(RECORDING)
  rawS3Key             String?
  hlsPath              String?
  durationSec          Int?
  sizeBytes            BigInt?
  mimeType             String?
  thumbnailUrl         String?
  egressJobId          String?
  bullmqJobId          String?
  transcodeStartedAt   DateTime?
  transcodeFinishedAt  DateTime?
  transcribeStartedAt  DateTime?
  transcribeFinishedAt DateTime?
  aiProcessStartedAt   DateTime?
  aiProcessFinishedAt  DateTime?
  retryCount           Int             @default(0)
  failureReason        String?         @db.Text
  expungedAt           DateTime?
  expungedBy           String?
  expungeReason        String?
  shareExpiresAt       DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  session     TeachingSession       @relation(fields: [sessionId], references: [id])
  transcripts Transcript[]
  qaItems     QaItem[]
  clips       Clip[]
  stages      RecordingStageEvent[]
  shares      RecordingShare[]

  @@index([status])
  @@index([pipelineStage])
  @@map("recordings")
}

model RecordingStageEvent {
  id            String          @id @default(cuid())
  recordingId   String
  stage         RecordingStatus
  startedAt     DateTime        @default(now())
  endedAt       DateTime?
  success       Boolean?
  errorMessage  String?         @db.Text
  attemptNumber Int             @default(1)
  metadata      Json?

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@index([recordingId])
  @@map("recording_stage_events")
}

model Transcript {
  id           String   @id @default(cuid())
  recordingId  String
  language     String // 'en' | 'hi' | 'te' | 'ta'
  source       String   @default("sarvam") // 'sarvam' | 'whisper' | 'manual'
  modelVersion String?
  content      String   @db.Text // post-PHI-redaction
  segments     Json // [{start, end, text, speaker}]
  diarized     Boolean  @default(false)
  piiRedacted  Boolean  @default(true)
  createdAt    DateTime @default(now())

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@unique([recordingId, language])
  @@index([recordingId])
  @@map("transcripts")
}

model QaItem {
  id           String    @id @default(cuid())
  recordingId  String
  userId       String
  timestampSec Int
  question     String    @db.Text
  answer       String?   @db.Text
  answeredById String?
  answeredAt   DateTime?
  pinned       Boolean   @default(false)
  likeCount    Int       @default(0)
  parentId     String? // W5: single-level reply thread (self-FK; app-level guard rejects nested replies)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  recording Recording    @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id])
  reactions QaReaction[]
  parent    QaItem?      @relation("QaThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   QaItem[]     @relation("QaThread")

  @@index([recordingId, timestampSec])
  @@index([userId])
  @@index([parentId])
  @@map("qa_items")
}

model QaReaction {
  id        String   @id @default(cuid())
  qaItemId  String
  userId    String
  kind      String   @default("LIKE")
  createdAt DateTime @default(now())

  qaItem QaItem @relation(fields: [qaItemId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([qaItemId, userId, kind])
  @@index([qaItemId])
  @@map("qa_reactions")
}

model Clip {
  id             String    @id @default(cuid())
  recordingId    String
  createdById    String
  title          String?
  kind           ClipKind  @default(REGULAR)
  startSec       Int
  endSec         Int
  s3Key          String?
  hlsPath        String?
  shareToken     String?   @unique
  shareExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@index([recordingId])
  @@index([createdById])
  @@index([kind])
  @@map("clips")
}

model Document {
  id               String         @id @default(cuid())
  uploadedById     String
  title            String
  description      String?        @db.Text
  kind             DocumentKind
  route            DocumentRoute  @default(UNCLASSIFIED)
  aiSuggestedRoute DocumentRoute?
  aiConfidence     Decimal?       @db.Decimal(3, 2)
  s3Key            String
  sizeBytes        BigInt
  mimeType         String
  pageCount        Int?
  status           DocumentStatus @default(UPLOADED)
  visibility       DocumentStatus @default(PRIVATE_FACULTY)
  phiScanStatus    String?
  phiScanResult    Json?
  deckForgeJobId   String?
  rejectionReason  String?
  expungedAt       DateTime?
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  uploader      User                  @relation("DocumentUploader", fields: [uploadedById], references: [id])
  tags          DocumentTag[]
  sessionLinks  DocumentSessionLink[]
  deckForgeJobs DeckForgeJob[]

  @@index([uploadedById])
  @@index([status])
  @@index([route])
  @@map("documents")
}

model DocumentTag {
  id         String @id @default(cuid())
  documentId String
  tag        String

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, tag])
  @@index([tag])
  @@map("document_tags")
}

model DocumentSessionLink {
  id                  String   @id @default(cuid())
  documentId          String
  sessionId           String
  linkedById          String
  visibleAfterSession Boolean  @default(true)
  isPreSession        Boolean  @default(false)
  preSessionRank      Int?
  createdAt           DateTime @default(now())

  document       Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  session        TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studyPackViews StudyPackView[]

  @@unique([documentId, sessionId])
  @@index([sessionId])
  @@index([sessionId, isPreSession])
  @@map("document_session_links")
}

model DeckForgeJob {
  id              String          @id @default(cuid())
  documentId      String
  requestedById   String
  status          DeckForgeStatus @default(QUEUED)
  inputTitle      String?
  template        String?
  outputS3Key     String?
  extractedPearls Json?
  analysisResult  Json? // W4 C10: { readabilityScore, slideDensityScore, visualBalanceScore, suggestions: [{ slideIdx, kind, message }] }
  slideCount      Int?
  errorMessage    String?         @db.Text
  phiBlocked      Boolean         @default(false)
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  document    Document @relation(fields: [documentId], references: [id])
  requestedBy User     @relation(fields: [requestedById], references: [id])

  @@index([documentId])
  @@index([status])
  @@map("deck_forge_jobs")
}

// ════════════════════════════════════════════════════════════════════════════
// TIER 6 — AI PIPELINE (8 tables)
// ════════════════════════════════════════════════════════════════════════════

model AiModel {
  id          String   @id @default(cuid())
  slug        String   @unique
  displayName String
  baseModel   String // 'qwen-2.5-7b' | 'qwen-2.5-14b' | 'gemini-2.5-flash'
  version     String
  modality    String // 'text' | 'vision' | 'embedding'
  provider    String // 'self-hosted' | 'sarvam' | 'google' | 'openai'
  active      Boolean  @default(true)
  config      Json?
