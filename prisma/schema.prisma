  caseId                   String?
  // Triple-H subscores (0-5 each)
  headClinicalReasoning    Int?
  headEvidenceBase         Int?
  headDifferentialBuilding Int?
  headInvestigationChoice  Int?
  heartEmpathy             Int?
  heartCommunication       Int?
