  lastRecalcAt  DateTime?
  evidenceCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  resident User             @relation(fields: [residentId], references: [id])
  recalcs  EpaRecalcEvent[]

  @@unique([residentId, epaCode])
  @@index([residentId])
  @@map("epa_records")
}

model EpaRecalcEvent {
  id            String    @id @default(cuid())
  epaRecordId   String
  previousLevel EpaLevel?
  newLevel      EpaLevel
  triggerType   String // 'DOPS' | 'MINICEX' | 'SCORING_EVENT' | 'MANUAL'
  triggerId     String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())

  record EpaRecord @relation(fields: [epaRecordId], references: [id], onDelete: Cascade)

  @@index([epaRecordId])
  @@map("epa_recalc_events")
}

model VcceItem {
  id               String       @id @default(cuid())
  code             String       @unique
  kind             VcceItemKind
  language         String       @default("en") // en | hi | te | ta | hx
  prompt           String       @db.Text
  expectedBehavior String       @db.Text
  severity         String // 'critical' | 'high' | 'medium' | 'low'
  tags             String[]
  active           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  results VcceResult[]

  @@index([kind])
  @@index([language])
