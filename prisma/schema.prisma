}

model RateLimit {
  id           String    @id @default(cuid())
  bucketKey    String // e.g. "login:email:user@x.com" or "login:ip:1.2.3.4"
  hitCount     Int       @default(0)
  windowStart  DateTime  @default(now())
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([bucketKey])
  @@index([blockedUntil])
  @@map("rate_limits")
}

model UserRoleHistory {
  id           String   @id @default(cuid())
  userId       String
  previousRole Role?
  newRole      Role
  changedBy    String
  reason       String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_role_history")
}

// ════════════════════════════════════════════════════════════════════════════
// TIER 1 — CORE LEARNER (12 tables)
// ════════════════════════════════════════════════════════════════════════════

model Topic {
  id            String   @id @default(cuid())
  slug          String
  name          String
  subspecialty  String? // Cornea, Glaucoma, Retina, Pediatric, etc.
  description   String?
  parentTopicId String?
  displayOrder  Int      @default(0)
  /// W6.11 tenancy. Topic curriculum is per-program — Cornea Fellowship
  /// has different topics than MS Ophthalmology. Slug is unique within
  /// program (the global @unique was relaxed for tenancy).
  programId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  program       Program        @relation(fields: [programId], references: [id])
  parent        Topic?         @relation("TopicHierarchy", fields: [parentTopicId], references: [id])
  children      Topic[]        @relation("TopicHierarchy")
  cases         Case[]
  caseTemplates CaseTemplate[]
  pearls        Pearl[]
  courses       Course[]
  atlasImages   AtlasImage[]

  @@unique([programId, slug])
  @@index([programId])
  @@index([parentTopicId])
  @@index([subspecialty])
  @@map("topics")
}

model Level {
  id          String   @id @default(cuid())
  levelNumber Int      @unique // 1-4
  name        String
  description String?
  minMastery  Int // score threshold
  createdAt   DateTime @default(now())

  userProgress UserLevelProgress[]

  @@map("levels")
}

model UserLevelProgress {
  id           String    @id @default(cuid())
  userId       String
  topicId      String
  levelId      String
  masteryScore Int       @default(0)
  unlockedAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  level Level @relation(fields: [levelId], references: [id])

  @@unique([userId, topicId, levelId])
  @@index([userId])
  @@index([topicId])
  @@map("user_level_progress")
}

model Case {
  id                  String     @id @default(cuid())
  residentId          String
  templateId          String?
  topicId             String?
  title               String
  patientAgeYears     Int?
  patientSex          String?
  presentingComplaint String?
  currentStage        CaseStage  @default(PATIENT_STORY)
  status              CaseStatus @default(ACTIVE)
  difficultyLevel     Int        @default(1)
  caseNotes           String?    @db.Text // faculty-loaded reference; PHI-scanned
  deletedAt           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  resident      User               @relation(fields: [residentId], references: [id])
  template      CaseTemplate?      @relation(fields: [templateId], references: [id])
  topic         Topic?             @relation(fields: [topicId], references: [id])
  conversations Conversation[]
  stageHistory  CaseStageHistory[]
  scoringEvents ScoringEvent[]

  @@index([residentId])
  @@index([templateId])
  @@index([topicId])
  @@index([status])
  @@index([currentStage])
