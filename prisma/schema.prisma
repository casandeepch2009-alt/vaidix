// W4-Sprint additions — Live Engagement, Hooks, Alerts, Kirkpatrick
// ════════════════════════════════════════════════════════════════════════════

// Per-participant time-series. Producers: Stream A (recording events),
// Stream D (hook responses, chat messages, hand raises, leaderboard updates).
// Consumers: Stream D (presenter alerts, readiness predictor — W11).
model EngagementSignal {
  id        String               @id @default(cuid())
  sessionId String
  userId    String
  kind      EngagementSignalKind
  value     Decimal?             @db.Decimal(6, 3) // optional numeric (e.g., attention score 0–1)
  metadata  Json?
  createdAt DateTime             @default(now())

  session TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([sessionId, userId, kind])
  @@index([userId, createdAt])
  @@map("engagement_signals")
}

// Auto-injected attention hook fired by the Hooks Engine (Stream D #4).
// Examples: T/F prompt, poll, one-word, repeat-the-concept, dilemma.
model LiveHook {
  id              String       @id @default(cuid())
  sessionId       String
  kind            LiveHookKind
  prompt          String       @db.Text
  options         Json? // for POLL: ["A", "B", "C"]; null for free-form
  correctOption   String? // if any
  explanation     String?      @db.Text
  intervalSeconds Int? // if recurring (e.g., every 6–8 min)
  scheduledAt     DateTime? // when this hook should fire
  firedAt         DateTime? // when it actually fired
  closedAt        DateTime? // when it stopped accepting responses
  createdById     String
  createdAt       DateTime     @default(now())

  session   TeachingSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  responses LiveHookResponse[]

  @@index([sessionId, scheduledAt])
  @@index([sessionId, firedAt])
  @@map("live_hooks")
}

model LiveHookResponse {
  id        String   @id @default(cuid())
  hookId    String
  userId    String
  response  String   @db.Text
  isCorrect Boolean?
  latencyMs Int? // time from hook fire to response — feeds engagement signals
  createdAt DateTime @default(now())

  hook LiveHook @relation(fields: [hookId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hookId, userId])
  @@index([userId])
  @@map("live_hook_responses")
}

// Private alerts shown ONLY to the presenter (Stream D #5).
// Computed from EngagementSignal aggregates by alert-evaluator (BullMQ-backed).
model PresenterAlert {
  id             String                 @id @default(cuid())
  sessionId      String
  presenterId    String
  kind           PresenterAlertKind
  severity       PresenterAlertSeverity @default(INFO)
  message        String                 @db.Text
  metadata       Json?
  acknowledgedAt DateTime?
  createdAt      DateTime               @default(now())

  session   TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  presenter User            @relation(fields: [presenterId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([presenterId, acknowledgedAt])
  @@map("presenter_alerts")
}

// Kirkpatrick L1–L4 evaluations (Stream D #11). L1 from post-session survey,
// L2 from quiz scores (auto), L3 from DOPS evidence (W8), L4 from Phase-2 outcomes.
model KirkpatrickEvaluation {
  id         String           @id @default(cuid())
  userId     String
  level      KirkpatrickLevel
  sessionId  String? // nullable: L4 may aggregate across many sessions
  score      Decimal          @db.Decimal(5, 2) // 0–100
  surveyData Json? // L1 reaction survey responses
  metadata   Json? // free-form (e.g. quiz IDs for L2)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  session  TeachingSession?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  evidence KirkpatrickEvidence[]

  @@index([userId, level])
  @@index([sessionId])
  @@map("kirkpatrick_evaluations")
}

model KirkpatrickEvidence {
  id           String   @id @default(cuid())
  evaluationId String
  evidenceType String // 'SCORING_EVENT' | 'DOPS' | 'MINI_CEX' | 'EPA' | 'SURVEY' | 'QUIZ'
  evidenceId   String // FK to the relevant table (loose — different per type)
  weight       Decimal  @default(1.0) @db.Decimal(4, 2)
  createdAt    DateTime @default(now())

  evaluation KirkpatrickEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@index([evidenceType, evidenceId])
  @@map("kirkpatrick_evidence")
}

// ════════════════════════════════════════════════════════════════════════════
// W5 — Breakouts + Recording Share
// ════════════════════════════════════════════════════════════════════════════
// Breakout: faculty splits a live session into N child rooms. Random or
// self-select grouping in Phase 1; AI auto-grouping ships in W11 with the
// readiness predictor (engagement signals are the input).
//
// BreakoutAgentLog mirrors the LIVEKIT-AGENT-CONTRACT pattern: the actual
// Python sidecar that joins each breakout as the AI Discussion Co-Facilitator
// is a separate deliverable. This repo defines the wire contract + storage.
// See docs/BREAKOUT-AGENT-CONTRACT.md.

enum BreakoutGroupingMode {
  RANDOM
  SELF_SELECT
  AI_AUTO // schema-only in Phase 1; route returns 501 until W11
}

enum BreakoutStatus {
  ACTIVE
  ENDED
}

enum BreakoutAgentLogKind {
  SUMMARY
  PROBE_QUESTION
  SILENCE_NUDGE
  UNANSWERED_QUESTION
  INTERVENTION
}

model Breakout {
  id              String               @id @default(cuid())
  sessionId       String
  createdById     String
  name            String
  groupingMode    BreakoutGroupingMode
  livekitRoomName String               @unique
  status          BreakoutStatus       @default(ACTIVE)
  endedAt         DateTime?
  endedById       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  session      TeachingSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdBy    User                  @relation("BreakoutCreator", fields: [createdById], references: [id])
  participants BreakoutParticipant[]
  agentLogs    BreakoutAgentLog[]

  @@index([sessionId])
  @@index([status])
  @@map("breakouts")
}

model BreakoutParticipant {
  id         String    @id @default(cuid())
  breakoutId String
  userId     String
  joinedAt   DateTime?
  leftAt     DateTime?
  createdAt  DateTime  @default(now())

  breakout Breakout @relation(fields: [breakoutId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([breakoutId, userId])
  @@index([userId])
  @@map("breakout_participants")
}

model BreakoutAgentLog {
  id         String               @id @default(cuid())
  breakoutId String
  kind       BreakoutAgentLogKind
  content    String               @db.Text
  metadata   Json?
  createdAt  DateTime             @default(now())

  breakout Breakout @relation(fields: [breakoutId], references: [id], onDelete: Cascade)

  @@index([breakoutId, createdAt])
  @@map("breakout_agent_logs")
}

model RecordingShare {
  id           String    @id @default(cuid())
  recordingId  String
  /// Legacy plaintext token column. Kept nullable across one release for
  /// safe rolling deploy; dropped in a follow-up migration. New rows leave
  /// this NULL — lookup is by `tokenHash` (HARDENING-PLAN item #12).
  token        String?
  /// sha256 hex of the raw URL token. Lookup index. Never reversible.
  tokenHash    String    @unique
  passwordHash String?
  expiresAt    DateTime
  createdById  String
  revokedAt    DateTime?
  revokedById  String?
  accessCount  Int       @default(0)
  lastAccessAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  recording Recording              @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  createdBy User                   @relation("RecordingShareCreator", fields: [createdById], references: [id])
  revokedBy User?                  @relation("RecordingShareRevoker", fields: [revokedById], references: [id])
  accesses  RecordingShareAccess[]

  @@index([recordingId])
  @@index([expiresAt])
  @@map("recording_shares")
}

model RecordingShareAccess {
  id         String   @id @default(cuid())
  shareId    String
  ipAddress  String?
  userAgent  String?  @db.Text
  succeeded  Boolean  @default(true)
  failReason String?
  accessedAt DateTime @default(now())

  share RecordingShare @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@index([shareId, accessedAt])
  @@map("recording_share_accesses")
}

// ════════════════════════════════════════════════════════════════════════════
// W6 — Pre-Conference Question Submission Engine (Feeddback #2)
// ════════════════════════════════════════════════════════════════════════════
// Residents submit questions ahead of a session and upvote others. A debounced
// BullMQ worker calls Gemini to cluster the submitted text into themes (label
// + summary + count) so the presenter sees the top-N anticipated concerns on
// their pre-session dashboard.
//
// Phase A uses Gemini for clustering (see src/server/services/pre-questions/
// cluster-questions.ts). Phase B will swap to Vaidix Core via the same
// AIProvider seam — no schema change needed.

enum PreSessionQuestionUrgency {
  LOW
  NORMAL
  HIGH
}

model PreSessionQuestion {
  id        String                    @id @default(cuid())
  sessionId String
  userId    String
  content   String                    @db.Text
  urgency   PreSessionQuestionUrgency @default(NORMAL)
  themeId   String?
  voteCount Int                       @default(0)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  session TeachingSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User                     @relation(fields: [userId], references: [id])
  theme   PreSessionQuestionTheme? @relation(fields: [themeId], references: [id], onDelete: SetNull)
  votes   PreSessionQuestionVote[]

  @@index([sessionId, voteCount])
  @@index([sessionId, createdAt])
  @@index([userId])
  @@index([themeId])
  @@map("pre_session_questions")
}

model PreSessionQuestionVote {
  id         String   @id @default(cuid())
  questionId String
  userId     String
  createdAt  DateTime @default(now())

  question PreSessionQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id])

  @@unique([questionId, userId])
  @@index([userId])
  @@map("pre_session_question_votes")
}

model PreSessionQuestionTheme {
  id            String   @id @default(cuid())
  sessionId     String
  label         String
  summary       String   @db.Text
  questionCount Int      @default(0)
  rank          Int      @default(0)
  generatedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  session   TeachingSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questions PreSessionQuestion[]

  @@index([sessionId, rank])
  @@map("pre_session_question_themes")
}

// ════════════════════════════════════════════════════════════════════════════
// W6.8 — Pre-Conference Polish (Study Pack + Pre-Cases)
// ════════════════════════════════════════════════════════════════════════════
// SessionPreCase: faculty assigns curated CaseTemplates as session prep.
// Residents instantiate them via the existing cases engine; completion writes
// an EngagementSignal of kind PRE_CASE_COMPLETED so the readiness predictor
// picks it up. `required` is a soft signal — the Study Pack nudges, but joining
// the live session is never blocked (project pedagogy is "difficult but fair",
// not punitive — see project_vaidix.md memory).
//
// StudyPackView: per-(session, learner) record of which pre-readings, pre-watch
// videos, and pre-cases the learner has interacted with. Distinct from
// EngagementSignal because we need uniqueness queries ("did user X view link Y")
// and FK joins back to the link/case. The service layer ALSO writes a matching
// EngagementSignal so the existing aggregation pipeline (presenter alerts,
// readiness) keeps working without a parallel codepath.

model SessionPreCase {
  id             String   @id @default(cuid())
  sessionId      String
  caseTemplateId String
  assignedById   String
  rank           Int      @default(0)
  required       Boolean  @default(false)
  createdAt      DateTime @default(now())

  session        TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  caseTemplate   CaseTemplate    @relation(fields: [caseTemplateId], references: [id], onDelete: Cascade)
  assignedBy     User            @relation("SessionPreCaseAssigner", fields: [assignedById], references: [id])
  studyPackViews StudyPackView[]

  @@unique([sessionId, caseTemplateId])
  @@index([sessionId, rank])
  @@index([caseTemplateId])
  @@map("session_pre_cases")
}

model StudyPackView {
  id             String    @id @default(cuid())
  sessionId      String
  userId         String
  documentLinkId String?
  preCaseId      String?
  viewedAt       DateTime  @default(now())
  durationSec    Int?
  completedAt    DateTime?

  session TeachingSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  link    DocumentSessionLink? @relation(fields: [documentLinkId], references: [id], onDelete: SetNull)
  preCase SessionPreCase?      @relation(fields: [preCaseId], references: [id], onDelete: SetNull)

  @@index([sessionId, userId])
  @@index([userId, viewedAt])
  @@index([sessionId, documentLinkId])
  @@index([sessionId, preCaseId])
  @@map("study_pack_views")
}

// ════════════════════════════════════════════════════════════════════════════
// Learning objectives — resident self-marks per objective per session
// ════════════════════════════════════════════════════════════════════════════
// Objectives themselves live as a Json array on TeachingSession.objectives
// (each item: { id, text, blooms, epaTag? }). This table stores per-(session,
// user, objectiveId) achievement marks the resident sets after a session.
// objectiveId is the cuid embedded in the Json — NOT a FK, because objectives
// can be edited and we want orphan marks to surface as "achieved an objective
// that no longer exists" rather than disappearing silently.

enum ObjectiveAchievementStatus {
  YES
  PARTLY
  NO
}

model SessionObjectiveAchievement {
  id          String                     @id @default(cuid())
  sessionId   String
  userId      String
  objectiveId String
  status      ObjectiveAchievementStatus
  note        String?                    @db.Text
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  session TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId, objectiveId])
  @@index([sessionId, objectiveId])
  @@index([userId])
  @@map("session_objective_achievements")
}
