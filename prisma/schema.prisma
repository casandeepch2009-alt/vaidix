model TeachingSession {
  id                  String                @id @default(cuid())
  title               String
  description         String?               @db.Text
  sessionType         SessionType
  hostId              String
  status              SessionStatus         @default(SCHEDULED)
  approvalStatus      SessionApprovalStatus @default(DRAFT)
  /// Anyone with the share-link can join the live call + chat. Independent of
  /// cohortId / invites — set any combination. List-surface visibility is
  /// driven by cohort membership / invite presence; openToAll alone makes a
  /// session link-joinable but not auto-listed in anyone's feed.
  openToAll           Boolean               @default(false)
  proposedBy          String
  approvedBy          String?
  approvedAt          DateTime?
  rejectedReason      String?
  cohortId            String?
  scheduledStart      DateTime
  scheduledEnd        DateTime
  actualStart         DateTime?
  actualEnd           DateTime?
  recurrenceRule      String?
  recurrenceUntil     DateTime?
  parentSessionId     String?
  shareToken          String?               @unique
  shareTokenExpiresAt DateTime?
  liveKitRoomSid      String?
  maxParticipants     Int                   @default(100)
  breakoutsEnabled    Boolean               @default(false)
  recordingEnabled    Boolean               @default(true)
  consentRequired     Boolean               @default(true)
  hlsBroadcast        Boolean               @default(false)
  /// W7 Webinar mode. When true, sessions surface a public registration page
  /// (`/webinar/[id]/register`) and registrants are auto-issued a SessionInvite
  /// granting VIEWER role. Distinct from regular INVITE_ONLY sessions which
  /// require admin-managed invitations.
  isWebinar           Boolean               @default(false)
  topicId             String?
  /// W6.11 tenancy. Sessions are owned by a program. Set at create time
  /// from the proposer's activeProgramId; cohort.programId must match.
  programId           String
  tags                String[]
  metadata            Json?
  // Structured learning objectives — array of { id, text, blooms, epaTag? }.
  // Stored as Json so curators can reorder/edit without a sub-table; resident
  // self-marks live in SessionObjectiveAchievement keyed by the objective id.
  objectives          Json?
  deletedAt           DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  program                Program                       @relation(fields: [programId], references: [id])
  host                   User                          @relation("SessionHost", fields: [hostId], references: [id])
  proposer               User                          @relation("SessionProposer", fields: [proposedBy], references: [id])
  approver               User?                         @relation("SessionApprover", fields: [approvedBy], references: [id])
  cohort                 Cohort?                       @relation(fields: [cohortId], references: [id])
  parentSession          TeachingSession?              @relation("SessionSeries", fields: [parentSessionId], references: [id])
  childSessions          TeachingSession[]             @relation("SessionSeries")
  participants           SessionParticipant[]
  chatMessages           SessionChatMessage[]
  recording              Recording?
  files                  SessionFile[]
  sharedNote             SharedNote?
  whiteboard             Whiteboard?
  webinarRegistrations   WebinarRegistration[]
  documentLinks          DocumentSessionLink[]
  bans                   SessionBan[]
  auditEvents            SessionAuditEvent[]
  invites                SessionInvite[]
  admissions             SessionAdmission[]
  approvalAudits         SessionApprovalAudit[]
  engagementSignals      EngagementSignal[]
  liveHooks              LiveHook[]
  presenterAlerts        PresenterAlert[]
  kirkpatrickEvaluations KirkpatrickEvaluation[]
  breakouts              Breakout[]
  preQuestions           PreSessionQuestion[]
  preQuestionThemes      PreSessionQuestionTheme[]
  preCases               SessionPreCase[]
  studyPackViews         StudyPackView[]
  objectiveAchievements  SessionObjectiveAchievement[]
  liveTranscripts        SessionTranscript[]
  promoShares            PromoShare[]

  @@index([programId])
  @@index([hostId])
  @@index([proposedBy])
  @@index([approvalStatus])
  @@index([openToAll])
  @@index([cohortId])
  @@index([status])
  @@index([scheduledStart])
  @@index([scheduledEnd])
  @@index([parentSessionId])
  @@map("teaching_sessions")
}

// Live captions persistence — written incrementally during a session by the
// captions producer (Deepgram for English; Sarvam for Indic in Phase 2). Kept
// distinct from `Transcript` (which is recordingId-keyed and produced by the
// post-recording batch transcribe-worker against the recorded audio file).
//
// Why a separate model: not every session is recorded (recordingEnabled may
// be false), and even for recorded sessions the live transcript is available
// minutes earlier than the post-batch one. Post-session export reads from
// SessionTranscript first, falls back to Transcript when finalized=false.
//
// Storage shape: a single Json `segments` array per (session, language) row,
// appended in-place by the publish endpoint. Cap enforced server-side
// (LIVE_TRANSCRIPT_MAX_SEGMENTS) so a stuck producer can't unbounded-grow.
model SessionTranscript {
  id          String    @id @default(cuid())
  sessionId   String
  language    String // 'en' | 'hi' | 'te' | 'ta' | 'kn' | 'ml' | 'mr' | 'bn' | 'ur'
  source      String    @default("deepgram") // 'deepgram' | 'sarvam' | 'manual'
  /// Append-only array of finalized segments. Each entry:
  /// `{ startMs, endMs, text, speakerId?, speakerName?, confidence? }`.
  /// Partial (interim) Deepgram results are NOT persisted — only finals.
  segments    Json      @default("[]")
  /// Concatenated finalized text. Maintained in lockstep with `segments` so
  /// the export endpoint and Gemini summary can read the full conversation
  /// without parsing JSON. Cap mirrors `segments`.
  contentText String    @default("") @db.Text
  /// Set true when the producer signals end-of-session (or a worker sweeps
  /// abandoned rows after timeout). Locks the row from further appends.
  finalized   Boolean   @default(false)
  startedAt   DateTime  @default(now())
  finalizedAt DateTime?
  updatedAt   DateTime  @updatedAt

  session      TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  qaPairs      PostSessionQa[]
  sjtCases     SjtCase[]
  pblScenarios PblScenario[]

  @@unique([sessionId, language])
  @@index([sessionId])
  @@map("session_transcripts")
}

