# ═══════════════════════════════════════════════════════════════════
# Vaidix — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# ─── Database ──────────────────────────────────────────────────────
# Postgres running natively on localhost:5432
# We create database "vaidix" in W0.6 (separate from BusinessOS)
#
# Connection pool (HARDENING-PLAN item #9): explicitly tune for prod-like
# workloads. Default Prisma pool is 5 — too small for live sessions + workers.
#   • dev: 10 connections is enough
#   • prod: 30 per app instance + ensure Postgres `max_connections` ≥ 150
#     when running app + workers + admin tools alongside
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/vaidix?schema=public&connection_limit=10&pool_timeout=20"

# ─── Redis ─────────────────────────────────────────────────────────
# Used by BullMQ (job queue) + NextAuth sessions + rate limiting
REDIS_URL="redis://localhost:6379"

# ─── NextAuth ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="REPLACE_WITH_64_CHAR_HEX_SECRET"

# ─── Email (Gmail SMTP) ────────────────────────────────────────────
# 1. Enable 2FA on Gmail account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password named "Vaidix"
# 4. Use the 16-char password below (NOT your Gmail login password)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your.vaidix@gmail.com"
EMAIL_PASSWORD="YOUR_16_CHAR_GMAIL_APP_PASSWORD"
EMAIL_FROM="Vaidix <your.vaidix@gmail.com>"

# ─── LiveKit (local Docker) ────────────────────────────────────────
# These values are read from livekit.yaml — see W0.9
LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="REPLACE_WITH_32_CHAR_SECRET"
# scripts/render-configs.sh substitutes this into egress.yaml so the egress
# Chrome bot can reach LiveKit from its container. Use the host LAN IP for
# a dev setup where LiveKit runs natively + egress runs in Docker; use
# ws://livekit:7880 when both run via docker-compose on vaidix-net.
LIVEKIT_INTERNAL_WS_URL="ws://localhost:7880"

# ─── TURN / coturn (only needed for `docker-compose.prod.yml` deploys) ─
# Local dev rarely needs TURN — host-network ICE candidates work fine. But
# scripts/render-configs.sh now validates these whenever it runs, even from
# a dev .env, so set them to dummies if you're rendering configs locally:
TURN_SHARED_SECRET="local-dev-dummy-secret-32-chars"
COTURN_EXTERNAL_IP="127.0.0.1"
COTURN_REALM="localhost"

# ─── MinIO (local S3-compatible) ───────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="vaidix-video"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_REGION="us-east-1"

# ─── AI Services ───────────────────────────────────────────────────
# Sarvam for Indic transcription; Gemini for Vaidix Core fallback
SARVAM_API_KEY=""
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
SARVAM_STT_MODEL="saaras:v3"

# Deepgram — live captions for English-only sessions (Phase 1).
# The browser receives short-lived scoped tokens minted from this key, so
# the master key never reaches the client. Indic / code-mix sessions still
# route to Sarvam Saaras (Phase 2 — currently shown as "coming soon" in UI).
DEEPGRAM_API_KEY=""
DEEPGRAM_MODEL="nova-3"

# ─── File Upload Limits ────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB="500"

# ─── Data Directory (E: drive) ─────────────────────────────────────
# Raw recordings, HLS segments, uploads — all stored here
VAIDIX_DATA_ROOT="E:/vaidix-data"
