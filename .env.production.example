# ════════════════════════════════════════════════════════════════════════════
# Vaidix — Production Environment Template
# ════════════════════════════════════════════════════════════════════════════
# Copy to `.env` on the production host, fill in real values, then encrypt:
#   age -p -o vaidix.env.enc .env
# At deploy time, scripts/load-env.sh decrypts back to `.env` (mode 0600).
#
# Hostnames assume Redis & MinIO are running via the SEPARATE compose files
# (docker-compose.redis.yml, docker-compose.minio.yml) on the same Docker
# network `vaidix-net`. If you put them on different hosts, replace `redis`
# and `minio` with the host's IP / DNS name.
# ════════════════════════════════════════════════════════════════════════════

# ─── Database (Postgres) ───────────────────────────────────────────────────
# Default: containerised Postgres via docker-compose.postgres.yml
#   - hostname `postgres` is the container on vaidix-net
#   - POSTGRES_PASSWORD must match the password embedded in DATABASE_URL
#
# When you migrate to RDS, replace `postgres:5432` with the RDS endpoint and
# add `&sslmode=require`. POSTGRES_USER / POSTGRES_PASSWORD then unused.
POSTGRES_USER="vaidix"
POSTGRES_PASSWORD="CHANGE_ME_POSTGRES_PASSWORD"
POSTGRES_DB="vaidix"
DATABASE_URL="postgresql://vaidix:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/vaidix?schema=public&connection_limit=30&pool_timeout=20"

# ─── Redis (docker-compose.redis.yml) ──────────────────────────────────────
# Hostname `redis` is the container name on vaidix-net.
#
# Auth is enabled. The same REDIS_PASSWORD is consumed by:
#   - docker-compose.redis.yml (--requirepass)
#   - app + workers via REDIS_URL (with :PASSWORD@)
#   - LiveKit Server via LIVEKIT_REDIS_PASSWORD env var
#   - Egress via egress.yaml.tpl, rendered to egress.yaml at deploy time
#     (run scripts/render-configs.sh before compose up)
# Use a strong alphanumeric-only password to avoid URL-encoding pain.
REDIS_PASSWORD="CHANGE_ME_STRONG_ALPHANUMERIC_PASSWORD"
REDIS_URL="redis://:CHANGE_ME_STRONG_ALPHANUMERIC_PASSWORD@redis:6379"

# ─── NextAuth ──────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_URL="https://vaidix.example.org"
NEXTAUTH_SECRET="CHANGE_ME_64_CHAR_HEX"

# ─── Bootstrap Admin (consumed by `prisma db seed` ONCE on first boot) ─────
# Invitation-only system: this is the only user planted directly into the DB.
# After login, this admin invites everyone else via /admin/invitations.
#
# REQUIRED in production. Seed throws if any are missing under NODE_ENV=production.
# Use a real email (for password resets) and a strong password.
#   Generate: node -e "console.log(require('crypto').randomBytes(18).toString('base64'))"
#
# After the first successful seed you can blank these out — they're only read
# at seed time, and the admin row is upserted (re-running seed won't reset
# the password as long as the email already exists, but it WILL update the hash
# if the env var is still set, so blanking is safer).
ADMIN_EMAIL="admin@vaidix.example.org"
ADMIN_MOBILE="+91XXXXXXXXXX"
ADMIN_NAME="Platform Admin"
ADMIN_PASSWORD="CHANGE_ME_STRONG_RANDOM_PASSWORD"

# ─── Email (SMTP) ──────────────────────────────────────────────────────────
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="vaidix-notify@example.org"
EMAIL_PASSWORD="CHANGE_ME_APP_PASSWORD"
EMAIL_FROM="Vaidix <vaidix-notify@example.org>"

# ─── LiveKit ───────────────────────────────────────────────────────────────
# Public WSS URL (nginx terminates TLS and proxies to livekit:7880).
LIVEKIT_URL="wss://vaidix.example.org/livekit"
LIVEKIT_API_KEY="CHANGE_ME_LIVEKIT_KEY"
LIVEKIT_API_SECRET="CHANGE_ME_LIVEKIT_SECRET_MIN_32_CHARS"
# Internal LiveKit WebSocket URL used by the egress Chrome bot (inside Docker).
# Keep on the vaidix-net Docker network: ws://livekit:7880 resolves to the
# vaidix-livekit container directly, skipping nginx + TLS. render-configs.sh
# substitutes this into egress.yaml at deploy time and fails fast if missing.
LIVEKIT_INTERNAL_WS_URL="ws://livekit:7880"

# ─── TURN / coturn (REQUIRED for participants behind symmetric NAT) ────────
# Without these, guests on mobile data / corporate Wi-Fi / behind firewalls
# cannot connect — they get host-only ICE candidates, can't reach the EC2
# Docker internal IP, and LiveKit reconnects every 15-30s ("guest's name
# keeps refreshing" symptom from the v2.4 incident).
#
# All three are rendered into BOTH turnserver.conf AND livekit.prod.yaml by
# scripts/render-configs.sh from the same .env values — impossible to drift.
# scripts/render-configs.sh REFUSES to render if any value is empty OR
# contains the string CHANGE_ME, so the literal placeholder cannot ship.
#
# TURN_SHARED_SECRET — shared password between coturn and LiveKit. Rotate by
# changing here, re-rendering, and `docker compose ... up -d --force-recreate
# livekit coturn`. Generate:
#   openssl rand -base64 24 | tr -d '+/=' | head -c 32
TURN_SHARED_SECRET="CHANGE_ME_32_CHAR_TURN_PASSWORD"

# COTURN_EXTERNAL_IP — the EC2 instance's public IPv4. coturn advertises this
# in TURN allocation responses; clients need to be able to route to it.
# Must be a bare IPv4 (e.g. 13.234.37.54), NOT a DNS name (DNS goes in REALM).
COTURN_EXTERNAL_IP="CHANGE_ME_EC2_PUBLIC_IPV4"

# COTURN_REALM — DNS name shown in TURN allocation responses + used as the
# host in LiveKit's turn_servers config. Typically a TURN-specific subdomain
# of your app domain. Does not need a separate cert — coturn uses static
# long-term credentials, not TLS-handshake auth.
COTURN_REALM="turn.example.org"

# ─── Object storage (docker-compose.minio.yml — or real AWS S3) ───────────
# For MinIO via the separate compose: S3_ENDPOINT=http://minio:9000
# For real AWS S3:                    leave S3_ENDPOINT empty, fill region
#
# S3_PUBLIC_ENDPOINT is the browser-reachable URL for the same storage.
# MinIO is on Docker's internal network (minio:9000), proxied at
# https://s3.vaidix.lvpei.org via nginx (see nginx/sites-enabled/s3.conf).
# Presigned PUT/GET URLs are signed against this host so browsers can reach them.
# Required in production — browsers cannot resolve "minio" (internal hostname).
S3_ENDPOINT="http://minio:9000"
S3_PUBLIC_ENDPOINT="https://s3.vaidix.example.org"
S3_BUCKET="vaidix-video"
S3_ACCESS_KEY="CHANGE_ME_S3_ACCESS_KEY"
S3_SECRET_KEY="CHANGE_ME_S3_SECRET_KEY_MIN_8_CHARS"
S3_REGION="us-east-1"

# ─── AI Services ───────────────────────────────────────────────────────────
AI_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
TRANSCRIPTION_PROVIDER="self_hosted"
SELF_HOSTED_TRANSCRIPTION_URL=""

# ─── WhatsApp (optional) ───────────────────────────────────────────────────
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ─── Live captions ingest (optional) ───────────────────────────────────────
LIVE_CAPTIONS_INGEST_SECRET=""

# ─── Limits & paths ────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB="500"
VAIDIX_DATA_ROOT="/var/lib/vaidix-data"
